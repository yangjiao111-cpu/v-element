{
  "name": "er-ui-element",
  "version": "1.0.1",
  "description": "components library by Vue3 + ts",
  "type": "module",
  "main": "./dist/umd/index/umd.cjs",
  "module": "./dist/es/index.js",
  "types": "./dist/types/core/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/es/index.js",
      "require": "./dist/umd/index.umd.cjs",
      "types": "./dist/types/core/index.d.ts"
    },
    "./dist/": {
      "import": "./dist/",
      "require": "./dist/"
    }
  },
  "sideEffects": [
    "./dist/index.css"
  ],
  "scripts": {
    "build": "run-p build-es build-umd",
    "build:watch": "run-p build-es:watch build-umd:watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build-umd": "vite build --config vite.umd.config.ts",
    "build-es": "vite build --config vite.es.config.ts",
    "build-umd:watch": "vite build --watch --config vite.umd.config.ts",
    "build-es:watch": "vite build --watch --config vite.es.config.ts",
    "release": "release-it"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "terser": "^5.46.0",
    "vite-plugin-compression2": "^2.5.0",
    "vite-plugin-dts": "^3.9.1"
  },
  "peerDependencies": {
    "vue": "^3.4.19"
  }
}